# Local Makefile / shell overrides. Copy to .env and edit.
# .env is gitignored — keep personal hostnames, tokens, and other
# machine-specific values here, not in the Makefile itself.
#
# Plain KEY=VALUE shell syntax so both `make` (via include + export) and
# `set -a; source .env; set +a` from a terminal work the same way.

# Live hub the session-monitor talks to (Tailscale hostname, ngrok URL, etc).
SESSION_MONITOR_LIVE_HUB_URL=http://your-machine.example.ts.net:8788

# Bearer token for the live hub. The string below is the public dev default
# from apps/hub; override with a real token when pointing at a non-dev hub.
SESSION_MONITOR_LIVE_HUB_TOKEN=agentcanvas-dev-token
