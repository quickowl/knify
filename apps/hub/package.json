{
  "name": "@knify/agentcanvas-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/start-local.mjs",
    "deploy": "wrangler deploy",
    "check:dashboard": "node scripts/check-dashboard-fixtures.mjs",
    "seed:dashboard": "node scripts/seed-dashboard.mjs",
    "smoke:naive-agents": "node scripts/seed-dashboard.mjs && node scripts/check-dashboard-fixtures.mjs",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "start-local": "node scripts/start-local.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260502.0",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.14.4"
  }
}
